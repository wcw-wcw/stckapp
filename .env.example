# Local development defaults to mock market data and mock notifications.
MARKET_DATA_PROVIDER=mock
SMS_PROVIDER=mock
ENABLE_REAL_NOTIFICATIONS=false

# Optional local live-data testing. Set MARKET_DATA_PROVIDER=alpaca only when
# you want outbound market-data API calls.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_FEED=iex
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets/v2

# Local persistence defaults to SQLite. For deployment prep only, set
# DATABASE_PROVIDER=postgres and provide DATABASE_URL in your deployment
# provider's secret store. Do not commit real connection strings.
DATABASE_PROVIDER=sqlite
DATABASE_URL=

# Add these only when the Twilio provider is enabled.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Use a long random value before auth routes are enabled.
AUTH_SECRET=

# Guardrails for real SMS delivery.
GLOBAL_DAILY_SMS_LIMIT=100
GLOBAL_DAILY_NOTIFICATION_LIMIT=100
